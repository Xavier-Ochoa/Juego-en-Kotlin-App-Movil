<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/gameContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- BallView se agrega programáticamente desde MainActivity.kt (Fase 2),
         insertada en el índice 0 para quedar DEBAJO de estos botones. -->

    <!-- Controles de personalización de la bolita (reto - nivel básico).
         Van sobre el Canvas del juego, en la esquina inferior izquierda. -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnChangeColor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="@string/btn_change_color"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnDecreaseSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="@string/btn_decrease_size"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnIncreaseSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_increase_size"
            android:textAllCaps="false" />

    </LinearLayout>

</FrameLayout>
